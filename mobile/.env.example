EXPO_PUBLIC_API_URL=http://localhost:3000

# Web OAuth Client ID (used by the server to verify tokens)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# iOS OAuth Client ID — Google Console → Create credentials → OAuth 2.0 Client ID
# Application type: iOS | Bundle ID: com.groco.mobile
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# Android OAuth Client ID — Google Console → Create credentials → OAuth 2.0 Client ID
# Application type: Android | Package: com.groco.mobile | SHA-1: run `eas credentials`
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
